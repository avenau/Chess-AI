#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND_DIR="$ROOT_DIR/chess_ai_backend"
FRONTEND_DIR="$ROOT_DIR/chess_ai_frontend"
RUN_DIR="$ROOT_DIR/.run"
BACKEND_LOG="$RUN_DIR/backend.log"
FRONTEND_LOG="$RUN_DIR/frontend.log"
BACKEND_URL="http://localhost:8080/api/chess/health"
FRONTEND_URL="http://localhost:5173"
JAVA_VERSION="$(cat "$ROOT_DIR/.java-version" 2>/dev/null || true)"
BACKEND_PID=""
FRONTEND_PID=""

require_command() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Missing required command: $cmd" >&2
    exit 1
  fi
}

prepare_java_home() {
  if [[ -n "${JAVA_HOME:-}" ]] && [[ -x "${JAVA_HOME}/bin/java" ]]; then
    return
  fi

  if command -v /usr/libexec/java_home >/dev/null 2>&1; then
    if [[ -n "$JAVA_VERSION" ]]; then
      local resolved_java_home
      resolved_java_home="$(/usr/libexec/java_home -v "$JAVA_VERSION" 2>/dev/null || true)"
      if [[ -n "$resolved_java_home" ]]; then
        export JAVA_HOME="$resolved_java_home"
        return
      fi
    fi

    local fallback_java_home
    fallback_java_home="$(/usr/libexec/java_home 2>/dev/null || true)"
    if [[ -n "$fallback_java_home" ]]; then
      export JAVA_HOME="$fallback_java_home"
      return
    fi
  fi

  echo "JAVA_HOME is not set and no local JDK was found." >&2
  exit 1
}

port_in_use() {
  local port="$1"
  lsof -ti tcp:"$port" >/dev/null 2>&1
}

wait_for_url() {
  local url="$1"
  local label="$2"
  local attempts=60

  for ((i = 1; i <= attempts; i++)); do
    if curl -fsS "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done

  echo "$label did not become ready in time." >&2
  return 1
}

cleanup() {
  local exit_code="$?"

  if [[ -n "$FRONTEND_PID" ]] && kill -0 "$FRONTEND_PID" >/dev/null 2>&1; then
    kill "$FRONTEND_PID" >/dev/null 2>&1 || true
  fi

  if [[ -n "$BACKEND_PID" ]] && kill -0 "$BACKEND_PID" >/dev/null 2>&1; then
    kill "$BACKEND_PID" >/dev/null 2>&1 || true
  fi

  wait "$FRONTEND_PID" >/dev/null 2>&1 || true
  wait "$BACKEND_PID" >/dev/null 2>&1 || true

  exit "$exit_code"
}

require_command curl
require_command lsof
require_command mvn
require_command npm
require_command open
prepare_java_home

if [[ ! -f "$FRONTEND_DIR/package.json" ]]; then
  echo "Frontend package.json not found at $FRONTEND_DIR" >&2
  exit 1
fi

if [[ ! -f "$BACKEND_DIR/pom.xml" ]]; then
  echo "Backend pom.xml not found at $BACKEND_DIR" >&2
  exit 1
fi

if [[ ! -d "$FRONTEND_DIR/node_modules" ]]; then
  echo "Frontend dependencies are not installed. Run 'cd chess_ai_frontend && npm install' first." >&2
  exit 1
fi

if port_in_use 8080; then
  echo "Port 8080 is already in use." >&2
  exit 1
fi

if port_in_use 5173; then
  echo "Port 5173 is already in use." >&2
  exit 1
fi

mkdir -p "$RUN_DIR"
: > "$BACKEND_LOG"
: > "$FRONTEND_LOG"

trap cleanup EXIT INT TERM

(
  cd "$BACKEND_DIR"
  mvn spring-boot:run
) >"$BACKEND_LOG" 2>&1 &
BACKEND_PID=$!

echo "Starting backend on http://localhost:8080"
wait_for_url "$BACKEND_URL" "Backend"
echo "Backend ready"

(
  cd "$FRONTEND_DIR"
  npm run dev -- --host 127.0.0.1
) >"$FRONTEND_LOG" 2>&1 &
FRONTEND_PID=$!

echo "Starting frontend on $FRONTEND_URL"
wait_for_url "$FRONTEND_URL" "Frontend"
echo "Frontend ready"

open "$FRONTEND_URL"
echo "Chess app is running. Press Ctrl+C to stop both servers."
echo "Backend log: $BACKEND_LOG"
echo "Frontend log: $FRONTEND_LOG"

wait "$BACKEND_PID" "$FRONTEND_PID"
