#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRONTEND_DIR="$ROOT_DIR/chess_ai_frontend"
RUN_DIR="$ROOT_DIR/.run"
FRONTEND_LOG="$RUN_DIR/frontend.log"
FRONTEND_URL="http://localhost:5173"
FRONTEND_PID=""

require_command() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Missing required command: $cmd" >&2
    exit 1
  fi
}

port_in_use() {
  local port="$1"
  lsof -ti tcp:"$port" >/dev/null 2>&1
}

prompt_terminate_port() {
  local port="$1"
  local pids

  pids="$(lsof -ti tcp:"$port" | paste -sd ' ' -)"
  if [[ -z "$pids" ]]; then
    return 0
  fi

  read -r -p "Port $port is already in use by PID(s): $pids. Terminate them? [y/N] " response
  if [[ ! "$response" =~ ^[Yy]$ ]]; then
    echo "Port $port is already in use." >&2
    return 1
  fi

  kill $pids
}

wait_for_url() {
  local url="$1"
  local label="$2"
  local attempts=60

  for ((i = 1; i <= attempts; i++)); do
    if curl -fsS "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done

  echo "$label did not become ready in time." >&2
  return 1
}

cleanup() {
  local exit_code="$?"

  if [[ -n "$FRONTEND_PID" ]] && kill -0 "$FRONTEND_PID" >/dev/null 2>&1; then
    kill "$FRONTEND_PID" >/dev/null 2>&1 || true
  fi

  wait "$FRONTEND_PID" >/dev/null 2>&1 || true

  exit "$exit_code"
}

require_command curl
require_command lsof
require_command npm
require_command open

if [[ ! -f "$FRONTEND_DIR/package.json" ]]; then
  echo "Frontend package.json not found at $FRONTEND_DIR" >&2
  exit 1
fi

if [[ ! -d "$FRONTEND_DIR/node_modules" ]]; then
  echo "Frontend dependencies are not installed. Run 'cd chess_ai_frontend && npm install' first." >&2
  exit 1
fi

if port_in_use 5173; then
  if ! prompt_terminate_port 5173; then
    exit 1
  fi
fi

mkdir -p "$RUN_DIR"
: > "$FRONTEND_LOG"

trap cleanup EXIT INT TERM

(
  cd "$FRONTEND_DIR"
  npm run dev -- --host 127.0.0.1
)

echo "Starting frontend on $FRONTEND_URL"
wait_for_url "$FRONTEND_URL" "Frontend"
echo "Frontend ready"

open "$FRONTEND_URL"
echo "Frontend is running. Press Ctrl+C to stop it."
echo "Frontend log: $FRONTEND_LOG"

wait "$FRONTEND_PID"
